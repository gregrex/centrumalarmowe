# Copy to docker-compose.override.yml for local dev overrides
# This file is gitignored — safe to put local secrets here

version: "3.9"

services:
  api:
    environment:
      - ASPNETCORE_ENVIRONMENT=Development
      - Security__RequireAuth=false
      - Security__EnableDevTokenEndpoint=true
      # Override JWT key for local dev only:
      - Security__Jwt__SigningKey=local-dev-key-minimum-32-chars-here

  admin:
    environment:
      - ASPNETCORE_ENVIRONMENT=Development
      - AdminAuth__Username=admin
      - AdminAuth__Password=localdevpassword
