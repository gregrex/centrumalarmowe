# Copy this file to .env and fill in real values before running docker-compose
# NEVER commit .env to the repository

# PostgreSQL credentials
POSTGRES_DB=alarm112
POSTGRES_USER=alarm112app
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# JWT secret (min 32 characters)
JWT_SIGNING_KEY=CHANGE_ME_minimum_32_characters_jwt_key

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Auth mode (true in production)
REQUIRE_AUTH=false

# Port overrides (optional)
API_PORT=5080
ADMIN_PORT=5081
DB_PORT=5432
REDIS_PORT=6379

# Environment
ASPNETCORE_ENVIRONMENT=Development
