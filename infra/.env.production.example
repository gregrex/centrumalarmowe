# Copy to infra/.env on stage/production and replace every placeholder.
# Never commit the real file.

ASPNETCORE_ENVIRONMENT=Production

POSTGRES_DB=alarm112
POSTGRES_USER=alarm112app
POSTGRES_PASSWORD=CHANGE_ME_production_db_password

REDIS_PASSWORD=CHANGE_ME_production_redis_password

JWT_SIGNING_KEY=CHANGE_ME_at_least_32_characters_long
REQUIRE_AUTH=true

ADMIN_USERNAME=alarm112-admin
ADMIN_PASSWORD=CHANGE_ME_production_admin_password

API_PORT=5080
ADMIN_PORT=5081
DB_PORT=5432
REDIS_PORT=6379
