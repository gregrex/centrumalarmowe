{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ContentBundles": {
    "DataRoot": "../../data"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:5081,http://localhost:5090"
  },
  "Security": {
    "RequireAuth": false,
    "EnableDevTokenEndpoint": true,
    "Jwt": {
      "Issuer": "Alarm112.Api",
      "Audience": "Alarm112.Client",
      "SigningKey": ""
    }
  }
}
