{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ContentBundles": {
    "DataRoot": "../../data"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:5081,http://localhost:5090",
    "AllowedMethods": "GET,POST"
  },
  "Security": {
    "RequireAuth": false,
    "EnableDevTokenEndpoint": true,
    "Jwt": {
      "Issuer": "Alarm112.Api",
      "Audience": "Alarm112.Client",
      "SigningKey": ""
    }
  }
}
