{
  "Security": {
    "RequireAuth": true,
    "EnableDevTokenEndpoint": false,
    "Jwt": {
      "Issuer": "Alarm112.Api",
      "Audience": "Alarm112.Client",
      "SigningKey": ""
    }
  },
  "AllowedHosts": "localhost",
  "Cors": {
    "AllowedOrigins": "https://admin.alarm112.pl",
    "AllowedMethods": "GET,POST"
  },
  "Swagger": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "Alarm112.Api",
      "Environment": "Production"
    }
  }
}
